      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Outfit:wght@100;200;300;400;500;600;700;800;900&display=swap');\n\n  :root {\n    --primary: #0d182a;\n    --secondary: #f4f2ee; /* Earthy Cream approximation from oklch(0.96 0.03 90) */\n    --background: #ffffff;\n    --border: #e2e8f0; /* Mapped from oklch(0.90 0.02 145) */\n    --foreground: #0d182a;\n  }\n\n  .font-serif { font-family: 'Cormorant Garamond', serif; }\n  .font-outfit { font-family: 'Outfit', sans-serif; }\n</style>\n\n<div class=\"bg-[var(--background)] min-h-[1200px] font-outfit text-[var(--primary)] selection:bg-[var(--primary)] selection:text-white\" data-kid=\"1\">\n  \n  <div class=\"w-full bg-[var(--primary)] text-[var(--secondary)] py-2.5 px-6 text-center\" data-kid=\"2\">\n    <p class=\"text-[9px] font-black uppercase tracking-[0.5em] opacity-90\" data-kid=\"3\">Curating the Art of Celebration • Now Booking for 2026</p>\n  </div>\n\n  \n  <header class=\"w-full border-b border-[var(--border)] bg-white/95 backdrop-blur-md sticky top-0 z-50\" data-kid=\"4\">\n    <div class=\"max-w-[1440px] mx-auto h-24 px-10 flex items-center justify-between gap-12\" data-kid=\"5\">\n      \n      <a href=\"/\" class=\"flex-shrink-0 group flex items-center gap-3\" data-kid=\"6\">\n        <div class=\"w-10 h-10 border border-[var(--primary)] rounded-full flex items-center justify-center font-serif text-xl italic group-hover:bg-[var(--primary)] group-hover:text-white transition-all duration-500\" data-kid=\"7\">V</div>\n        <h1 class=\"font-serif text-3xl font-semibold italic text-[var(--primary)] tracking-tight\" data-kid=\"8\">Vownest</h1>\n      </a>\n\n      \n      <nav class=\"hidden lg:flex items-center space-x-12\" data-kid=\"9\">\n        <a href=\"#\" class=\"text-[10px] font-black uppercase tracking-[0.4em] text-[var(--primary)]/50 hover:text-[var(--primary)] transition-all relative py-2 group\" data-kid=\"10\">\n          Home\n          <span class=\"absolute bottom-0 left-0 w-0 h-[1.5px] bg-[var(--primary)] transition-all duration-300 group-hover:w-full\" data-kid=\"11\"></span>\n        </a>\n        <a href=\"#\" class=\"text-[10px] font-black uppercase tracking-[0.4em] text-[var(--primary)]/50 hover:text-[var(--primary)] transition-all relative py-2 group\" data-kid=\"12\">\n          Services\n          <span class=\"absolute bottom-0 left-0 w-0 h-[1.5px] bg-[var(--primary)] transition-all duration-300 group-hover:w-full\" data-kid=\"13\"></span>\n        </a>\n        <a href=\"#\" class=\"text-[10px] font-black uppercase tracking-[0.4em] text-[var(--primary)]/50 hover:text-[var(--primary)] transition-all relative py-2 group\" data-kid=\"14\">\n          Events\n          <span class=\"absolute bottom-0 left-0 w-0 h-[1.5px] bg-[var(--primary)] transition-all duration-300 group-hover:w-full\" data-kid=\"15\"></span>\n        </a>\n        <a href=\"#\" class=\"text-[10px] font-black uppercase tracking-[0.4em] text-[var(--primary)]/50 hover:text-[var(--primary)] transition-all relative py-2 group\" data-kid=\"16\">\n          About\n          <span class=\"absolute bottom-0 left-0 w-0 h-[1.5px] bg-[var(--primary)] transition-all duration-300 group-hover:w-full\" data-kid=\"17\"></span>\n        </a>\n      </nav>\n\n      \n      <div class=\"flex-1 max-w-sm hidden xl:block\" data-kid=\"18\">\n        <div class=\"relative group\" data-kid=\"19\">\n          <input type=\"text\" placeholder=\"Explore venues & services...\" class=\"w-full bg-[var(--secondary)]/40 border-b border-transparent focus:border-[var(--primary)] px-2 py-2.5 text-[11px] font-medium tracking-wide outline-none transition-all placeholder:text-[var(--primary)]/30\" data-kid=\"20\">\n          <svg class=\"absolute right-2 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--primary)]/30\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" data-kid=\"21\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2.5\" d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\" data-kid=\"22\"></path>\n          </svg>\n        </div>\n      </div>\n\n      \n      <div class=\"flex items-center space-x-8\" data-kid=\"23\">\n        \n        <button class=\"hidden md:flex items-center space-x-2 text-[10px] font-black uppercase tracking-[0.3em] text-[var(--primary)]/60 hover:text-[var(--primary)] transition-colors\" data-kid=\"24\">\n          <span data-kid=\"25\">EN</span>\n          <svg class=\"w-3 h-3\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"26\"><path d=\"M19 9l-7 7-7-7\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"27\"></path></svg>\n        </button>\n\n        \n        <div class=\"flex items-center space-x-3\" data-kid=\"28\">\n          <a href=\"#\" class=\"text-[10px] font-black uppercase tracking-[0.3em] px-4 py-3 hover:text-[var(--primary)]/70 transition-colors\" data-kid=\"29\">Sign In</a>\n          <a href=\"#\" class=\"bg-[var(--primary)] text-white text-[10px] font-black uppercase tracking-[0.3em] px-10 py-4 rounded-xs hover:bg-[var(--primary)]/90 transition-all border border-[var(--primary)]\" data-kid=\"30\">Get Started</a>\n        </div>\n\n        \n        <button class=\"lg:hidden p-2 text-[var(--primary)]\" data-kid=\"31\">\n          <svg class=\"w-7 h-7\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"32\"><path d=\"M4 9h16M4 15h16\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"33\"></path></svg>\n        </button>\n      </div>\n    </div>\n  </header>\n\n  \n  <main class=\"max-w-[1440px] mx-auto px-10 py-32\" data-kid=\"34\">\n     <div class=\"grid lg:grid-cols-2 gap-24 items-center\" data-kid=\"35\">\n        <div class=\"space-y-12\" data-kid=\"36\">\n           <div class=\"flex items-center gap-4\" data-kid=\"37\">\n              <span class=\"w-12 h-[1px] bg-[var(--primary)]\" data-kid=\"38\"></span>\n              <span class=\"text-[10px] font-black uppercase tracking-[0.5em] text-[var(--primary)]/40\" data-kid=\"39\">Exclusive Wedding Management</span>\n           </div>\n           <h2 class=\"font-serif text-8xl text-[var(--primary)] leading-[1.05] tracking-tight\" data-kid=\"40\">Sophistication <br data-kid=\"41\">in Every <br data-kid=\"42\">Moment.</h2>\n           <p class=\"text-lg text-[var(--primary)]/60 font-light max-w-md leading-relaxed italic\" data-kid=\"43\">A dedicated ecosystem for the modern couple, blending high-tech coordination with high-end aesthetics.</p>\n           <div class=\"flex items-center space-x-8 pt-4\" data-kid=\"44\">\n              <button class=\"bg-[var(--primary)] text-white text-[11px] font-black uppercase tracking-[0.4em] px-12 py-6 rounded-xs hover:scale-[1.02] transition-transform\" data-kid=\"45\">Inquire Now</button>\n              <button class=\"text-[11px] font-black uppercase tracking-[0.4em] flex items-center group\" data-kid=\"46\">\n                 Our Collections \n                 <svg class=\"ml-4 w-5 h-5 transition-transform group-hover:translate-x-2\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"47\"><path d=\"M14 5l7 7m0 0l-7 7m7-7H3\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"48\"></path></svg>\n              </button>\n           </div>\n        </div>\n        <div class=\"relative\" data-kid=\"49\">\n           <div class=\"aspect-[4/5] bg-[var(--secondary)] overflow-hidden rounded-xs\" data-kid=\"50\">\n              <img src=\"https://images.unsplash.com/photo-1511795409834-ef04bbd61622?auto=format&w=800&q=80&fit=crop\" class=\"w-full h-full object-cover grayscale-[0.2]\" alt=\"Luxe Wedding Reception\" data-kid=\"51\">\n           </div>\n           \n           <div class=\"absolute -bottom-12 -left-12 bg-whi