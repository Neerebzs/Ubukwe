      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Outfit:wght@100..900&display=swap');\n\n  :root {\n    --primary: #0d182a;\n    --secondary: oklch(0.96 0.03 90);\n    --border: oklch(0.90 0.02 145);\n    --foreground: oklch(0.25 0.02 145);\n  }\n\n  .font-serif-italic {\n    font-family: 'Cormorant Garamond', serif;\n    font-style: italic;\n  }\n\n  .font-outfit {\n    font-family: 'Outfit', sans-serif;\n  }\n</style>\n\n<div class=\"w-full bg-(--secondary) border-b border-(--border) font-outfit\" data-kid=\"1\">\n  \n  <div class=\"w-full border-b border-(--border) py-2 bg-white px-4 flex justify-center\" data-kid=\"2\">\n    <p class=\"text-[10px] tracking-[0.2em] uppercase text-(--primary) font-semibold\" data-kid=\"3\">\n      Curating Unforgettable Moments Since 2024\n    </p>\n  </div>\n\n  <header class=\"container mx-auto px-6 py-4 flex items-center justify-between gap-8\" data-kid=\"4\">\n    \n    <div class=\"flex-shrink-0\" data-kid=\"5\">\n      <a href=\"/\" class=\"flex flex-col items-start leading-none group\" data-kid=\"6\">\n        <span class=\"font-serif-italic text-3xl font-bold text-(--primary) tracking-tight\" data-kid=\"7\">Ubukwe</span>\n        <span class=\"text-[10px] tracking-[0.4em] uppercase text-(--primary)/60 mt-0.5 ml-1\" data-kid=\"8\">Hub Collective</span>\n      </a>\n    </div>\n\n    \n    <div class=\"flex-1 max-w-xl hidden lg:block\" data-kid=\"9\">\n      <div class=\"relative group\" data-kid=\"10\">\n        <div class=\"absolute inset-y-0 left-4 flex items-center pointer-events-none\" data-kid=\"11\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"text-(--primary)/40\" data-kid=\"12\"><circle cx=\"11\" cy=\"11\" r=\"8\" data-kid=\"13\"></circle><path d=\"m21 21-4.3-4.3\" data-kid=\"14\"></path></svg>\n        </div>\n        <input type=\"text\" placeholder=\"Search vendors, venues, or inspiration...\" class=\"w-full bg-white border border-(--border) rounded-full py-2.5 pl-11 pr-4 text-sm text-(--primary) placeholder:text-(--primary)/30 focus:outline-hidden focus:ring-1 focus:ring-(--primary) transition-all\" data-kid=\"15\">\n      </div>\n    </div>\n\n    \n    <div class=\"flex items-center gap-8\" data-kid=\"16\">\n      \n      <nav class=\"hidden md:flex items-center gap-8\" data-kid=\"17\">\n        <a href=\"/\" class=\"font-serif-italic text-lg text-(--primary) hover:text-(--primary)/70 transition-colors\" data-kid=\"18\">Home</a>\n        <a href=\"/services\" class=\"font-serif-italic text-lg text-(--primary) hover:text-(--primary)/70 transition-colors\" data-kid=\"19\">Services</a>\n        <a href=\"/events\" class=\"font-serif-italic text-lg text-(--primary) hover:text-(--primary)/70 transition-colors\" data-kid=\"20\">Events</a>\n        <a href=\"/about\" class=\"font-serif-italic text-lg text-(--primary) hover:text-(--primary)/70 transition-colors\" data-kid=\"21\">About</a>\n      </nav>\n\n      <div class=\"h-8 w-px bg-(--border) hidden md:block\" data-kid=\"22\"></div>\n\n      \n      <div class=\"flex items-center gap-4\" data-kid=\"23\">\n        <a href=\"/auth/signin\" class=\"text-[11px] font-bold uppercase tracking-[0.2em] text-(--primary) hover:opacity-70 transition-opacity\" data-kid=\"24\">\n          Sign In\n        </a>\n        <a href=\"/auth/signup\" class=\"bg-(--primary) text-white text-[11px] font-bold uppercase tracking-[0.2em] px-6 py-3 rounded-full hover:bg-(--primary)/90 transition-all border border-(--primary)\" data-kid=\"25\">\n          Get Started\n        </a>\n      </div>\n\n      \n      <button class=\"lg:hidden p-2 text-(--primary)\" data-kid=\"26\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"27\"><line x1=\"4\" x2=\"20\" y1=\"12\" y2=\"12\" data-kid=\"28\"></line><line x1=\"4\" x2=\"20\" y1=\"6\" y2=\"6\" data-kid=\"29\"></line><line x1=\"4\" x2=\"20\" y1=\"18\" y2=\"18\" data-kid=\"30\"></line></svg>\n      </button>\n    </div>\n  </header>\n</div>\n\n\n<div class=\"lg:hidden w-full bg-(--secondary) px-6 pb-4 border-b border-(--border)\" data-kid=\"31\">\n  <div class=\"relative\" data-kid=\"32\">\n    <div class=\"absolute inset-y-0 left-4 flex items-center pointer-events-none\" data-kid=\"33\">\n      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"text-(--primary)/40\" data-kid=\"34\"><circle cx=\"11\" cy=\"11\" r=\"8\" data-kid=\"35\"></circle><path d=\"m21 21-4.3-4.3\" data-kid=\"36\"></path></svg>\n    </div>\n    <input type=\"text\" placeholder=\"Search...\" class=\"w-full bg-white border border-(--border) rounded-full py-3 pl-11 pr-4 text-sm text-(--primary) focus:outline-hidden\" data-kid=\"37\">\n  </div>\n</div>",
