      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&display=swap');\n\n  :root {\n    --background: #ffffff;\n    --foreground: #2d3436;\n    --primary: #0d182a;\n    --primary-foreground: #ffffff;\n    --border: #e2e8f0;\n    --accent: #668c65;\n  }\n\n  .font-outfit { font-family: 'Outfit', sans-serif; }\n  .font-serif { font-family: 'Cormorant Garamond', serif; }\n</style>\n\n<div class=\"min-h-screen bg-slate-50 font-outfit text-[var(--foreground)]\" data-kid=\"1\">\n  \n  <header class=\"sticky top-0 z-50 w-full border-b border-[var(--border)] bg-[var(--background)] py-4\" data-kid=\"2\">\n    <div class=\"container mx-auto flex items-center justify-between px-6\" data-kid=\"3\">\n      \n      <div class=\"flex items-center gap-2\" data-kid=\"4\">\n        <div class=\"flex h-10 w-10 items-center justify-center rounded-lg bg-[var(--primary)] text-white\" data-kid=\"5\">\n          <i data-lucide=\"heart\" class=\"h-6 w-6\" data-kid=\"6\"></i>\n        </div>\n        <div class=\"flex flex-col\" data-kid=\"7\">\n          <span class=\"font-serif text-2xl font-bold leading-none italic text-[var(--accent)]\" data-kid=\"8\">Vownest</span>\n          <span class=\"text-[10px] font-bold tracking-[0.2em] uppercase text-slate-400\" data-kid=\"9\">Collective</span>\n        </div>\n      </div>\n\n      \n      <div class=\"hidden lg:flex flex-1 max-w-md mx-12\" data-kid=\"10\">\n        <div class=\"relative w-full\" data-kid=\"11\">\n          <div class=\"absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400\" data-kid=\"12\">\n            <i data-lucide=\"search\" class=\"h-4 w-4\" data-kid=\"13\"></i>\n          </div>\n          <input type=\"text\" class=\"block w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-[var(--border)] rounded-xl text-sm focus:outline-hidden focus:ring-1 focus:ring-[var(--primary)] transition-all placeholder:text-slate-400\" placeholder=\"Search vendors, events, or inspiration...\" data-kid=\"14\">\n          <div class=\"absolute inset-y-0 right-0 flex items-center pr-2\" data-kid=\"15\">\n            <kbd class=\"hidden sm:inline-flex items-center gap-1 rounded border border-slate-200 bg-white px-1.5 font-sans text-[10px] font-medium text-slate-400 opacity-100\" data-kid=\"16\">\n              <span class=\"text-xs\" data-kid=\"17\">⌘</span>K\n            </kbd>\n          </div>\n        </div>\n      </div>\n\n      \n      <nav class=\"hidden md:flex items-center gap-8\" data-kid=\"18\">\n        <a href=\"#\" class=\"text-sm font-medium hover:text-[var(--accent)] transition-colors\" data-kid=\"19\">Services</a>\n        <a href=\"#\" class=\"text-sm font-medium hover:text-[var(--accent)] transition-colors\" data-kid=\"20\">Events</a>\n        <a href=\"#\" class=\"text-sm font-medium hover:text-[var(--accent)] transition-colors\" data-kid=\"21\">About</a>\n        <div class=\"h-4 w-px bg-[var(--border)]\" data-kid=\"22\"></div>\n        <div class=\"flex items-center gap-3\" data-kid=\"23\">\n          <button class=\"px-5 py-2.5 text-sm font-semibold hover:bg-slate-50 rounded-xl transition-all\" data-kid=\"24\">Log in</button>\n          <button class=\"px-6 py-2.5 text-sm font-semibold bg-[var(--primary)] text-white rounded-xl transition-all\" data-kid=\"25\">Get Started</button>\n        </div>\n      </nav>\n\n      \n      <div class=\"flex items-center gap-4 md:hidden\" data-kid=\"26\">\n        <button class=\"p-2 text-slate-600\" data-kid=\"27\">\n          <i data-lucide=\"search\" class=\"h-5 w-5\" data-kid=\"28\"></i>\n        </button>\n        <button class=\"p-2 text-slate-600\" data-kid=\"29\">\n          <i data-lucide=\"menu\" class=\"h-6 w-6\" data-kid=\"30\"></i>\n        </button>\n      </div>\n    </div>\n  </header>\n\n  \n  <main class=\"container mx-auto px-6 py-12\" data-kid=\"31\">\n    <div class=\"max-w-4xl mx-auto space-y-8\" data-kid=\"32\">\n      <div class=\"space-y-4\" data-kid=\"33\">\n        <h1 class=\"text-4xl md:text-6xl font-serif italic text-slate-900 leading-tight\" data-kid=\"34\">Your wedding, perfectly <span class=\"text-[var(--accent)] underline decoration-1 underline-offset-8\" data-kid=\"35\">orchestrated</span>.</h1>\n        <p class=\"text-lg text-slate-600 max-w-xl\" data-kid=\"36\">The complete management system for modern couples and premium service providers.</p>\n      </div>\n      \n      \n      <div class=\"md:hidden mt-20 p-6 bg-white border border-[var(--border)] rounded-2xl\" data-kid=\"37\">\n        <p class=\"text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-6\" data-kid=\"38\">Mobile Header Interaction</p>\n        <div class=\"flex items-center justify-between border-b border-slate-100 pb-4 mb-4\" data-kid=\"39\">\n           <div class=\"flex items-center gap-2\" data-kid=\"40\">\n            <div class=\"h-8 w-8 bg-[var(--primary)] rounded-lg flex items-center justify-center\" data-kid=\"41\">\n              <i data-lucide=\"heart\" class=\"h-4 w-4 text-white\" data-kid=\"42\"></i>\n            </div>\n            <span class=\"font-serif italic font-bold text-lg text-[var(--accent)]\" data-kid=\"43\">Vownest</span>\n          </div>\n          <i data-lucide=\"x\" class=\"h-6 w-6 text-slate-400\" data-kid=\"44\"></i>\n        </div>\n        <nav class=\"space-y-6 py-4\" data-kid=\"45\">\n          <a href=\"#\" class=\"flex items-center justify-between text-lg font-medium group\" data-kid=\"46\">\n            <span data-kid=\"47\">Home</span>\n            <i data-lucide=\"chevron-right\" class=\"h-4 w-4 text-slate-300 group-hover:text-[var(--accent)] transition-colors\" data-kid=\"48\"></i>\n          </a>\n          <a href=\"#\" class=\"flex items-center justify-between text-lg font-medium group\" data-kid=\"49\">\n            <span data-kid=\"50\">Services</span>\n            <i data-lucide=\"chevron-right\" class=\"h-4 w-4 text-slate-300 group-hover:text-[var(--accent)] transition-colors\" data-kid=\"51\"></i>\n          </a>\n          <a href=\"#\" class=\"flex items-center justify-between text-lg font-medium group\" data-kid=\"52\">\n            <span data-kid=\"53\">Events</span>\n            <i data-lucide=\"chevron-right\" class=\"h-4 w-4 text-slate-300 group-hover:text-[var(--accent)] transition-colors\" data-kid=\"54\"></i>\n          </a>\n        </nav>\n        <div class=\"mt-8 space-y-3\" data-kid=\"55\">\n          <button class=\"w-full py-4 text-sm font-bold bg-[var(--primary)] text-white rounded-xl\" data-kid=\"56\">Get Started</button>\n          <button class=\"w-full py-4 text-sm font-bold border border-[var(--border)] rounded-xl\" data-kid=\"57\">Log in</button>\n        </div>\n      </div>\n    </div>\n  </main>\n</div>\n\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"58\"></script>\n<script data-kid=\"59\">\n  lucide.createIcons();\n</script>",
